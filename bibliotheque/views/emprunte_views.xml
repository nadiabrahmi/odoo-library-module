<odoo>
    <data>
        <!-- explicit list view definition -->

        <record model="ir.ui.view" id="emprunte_list_view">
            <field name="name">List des empruntes</field>
            <field name="model">bibliotheque.emprunte</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="emprunteur_id"/>
                    <field name="etiquete" options="{'color_field': 'color'}"/>
                    <field name="livre_id"/>
                    <field name="reference"/>
                    <field name="date_emprunte"/>
                    <field name="is_adhere"/>
                    <field name="date_retour" attrs="{'invisible':[('is_adhere', '=', False )]}"/>
                </tree>
            </field>
        </record>
        <!--   form view-->
        <record model="ir.ui.view" id="emprunte_form_view">
            <field name="name">bibliotheque.emprunte.form</field>
            <field name="model">bibliotheque.emprunte</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div name="button_box" class="oe_button_box">
                        </div>
                        <div>
                            <field name="image" widget="image" class="oe_avatar"
                                   options='{"preview_image": "image", "zoom": true, "size": [140, 140]}'/>
                        </div>
                        <div class="oe_title">
                            <h1 class="d-flex flex-row">
                                <field name="emprunteur_id" placeholder="Emprunteur"/>
                            </h1>
                            <h2>
                                <field name="etiquete" placeholder="etiquette"/>
                            </h2>
                        </div>
                        <group>
                            <field name="livre_id"/>
                            <field name="reference"/>
                            <field name="date_emprunte"/>
                            <field name="is_adhere"/>
                            <field name="date_retour" attrs="{'invisible':[('is_adhere', '=', False )]}"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"></field>
                        <field name="message_ids" widget="mail_thread"></field>
                    </div>
                </form>
            </field>
        </record>
        <record id="emprunte_view_kanban" model="ir.ui.view">
            <field name="name">bibliotheque.emprunte.kanban</field>
            <field name="model">bibliotheque.emprunte</field>
            <field name="arch" type="xml">
                <kanban class="o_res_partner_kanban" create="true">
                    <field name="color" invisible="1"/>
                    <field name="image"/>
                    <field name="livre_id"/>
                    <field name="reference"/>
                    <templates style="background-color:grey">
                        <t t-name="kanban-box">
                            <div t-attf-class="#{kanban_color(record.color.raw_value)} oe_kanban_content oe_kanban_global_click">
                                <div class="o_kanban_image">
                                    <field name="image" widget="image"
                                           options='{"preview_image": "image", "zoom": true, "size": [120, 120]}'/>
                                </div>
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="emprunteur_id"/>
                                    </strong>
                                    <ul>
                                        <br/>
                                        <li>
                                            <strong>Livre :</strong>
                                            <field name="livre_id"/>
                                        </li>
                                        <br/>
                                        <li>
                                            <strong>Référence :</strong>
                                            <field name="reference"/>
                                        </li>
                                        <br/>
                                        <li>
                                            <strong>Date de prêt :</strong>
                                            <field name="date_emprunte"/>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        <record id="view_emprunte_graph" model="ir.ui.view">
            <field name="name">bibliotheque.emprunte.graph</field>
            <field name="model">bibliotheque.emprunte</field>
            <field name="arch" type="xml">
                <graph string="présentation graphique" sample="1">
                    <field name="is_adhere"/>
                </graph>
            </field>
        </record>

        <!--        recherche group by-->
        <record id="emprunte_search_view" model="ir.ui.view">
            <field name="name">bibliotheque.search.view</field>
            <field name="model">bibliotheque.emprunte</field>
            <field name="arch" type="xml">
                <search string="Emprunte">
                    <field name="emprunteur_id"/>
                    <field name="livre_id"/>
                    <filter name="si_adhere" string="non retourné" icon="terp-partner"
                            domain="[('is_adhere', '=', False)]"/>
                    <filter name="group_by_si_adhere" string="retourné" icon="terp-partner"
                            domain="[('is_adhere', '=', True)]"/>
                </search>
            </field>
        </record>

        <!-- actions opening views on models -->
        <record model="ir.actions.act_window" id="emprunte_action_window">
            <field name="name">List des emprunteurs</field>
            <field name="res_model">bibliotheque.emprunte</field>
            <field name="context">{"search_default_si_adhere":1}</field>
            <field name="view_mode">tree,kanban,graph,form</field>
        </record>

        <!-- Top menu item -->

        <menuitem name="Bibliothèque" id="bibliotheque.menu_root"/>

        <!-- menu categories -->

        <menuitem name="Emprunteurs" id="emprunteurs_menu_cat" parent="bibliotheque.menu_root"
                  action="emprunte_action_window" sequence="1"/>

    </data>
</odoo>