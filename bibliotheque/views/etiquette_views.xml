<odoo>
    <data>
        <!-- explicit list view definition -->

        <record model="ir.ui.view" id="etiquette_list_view">
            <field name="name">List des etiquettes</field>
            <field name="model">bibliotheque.etiquette</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="color" widget="color_picker"/>
                </tree>
            </field>
        </record>

        <!--   form view-->
        <record model="ir.ui.view" id="etiquette_form_view">
            <field name="name">bibliotheque.etiquette.form</field>
            <field name="model">bibliotheque.etiquette</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="nom etiquette"/>
                            </h1>
                        </div>
                        <group>
                            <field name="reference"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <notebook>
                            <page string="Livres">
                                <field name="livres_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!--        view kanban-->
        <record id="category_view_kanban" model="ir.ui.view">
            <field name="name">bibliotheque.etiquette.kanban</field>
            <field name="model">bibliotheque.etiquette</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" create="true">
                    <templates style="background-color:grey">
                        <t t-name="kanban-box">
                            <div t-attf-class="#{kanban_color(record.color.raw_value)} oe_kanban_content oe_kanban_global_click"
                                 class="col-2">
                                <div class="row">
                                    <div class="col-4">
                                        <field name="color" invisible="1"/>
                                    </div>
                                    <div class="col-4">
                                        <p>
                                            <strong>
                                                <field name="name"/>
                                            </strong>

                                        </p>
                                        <p>
                                            <field name="reference"/>
                                        </p>
                                    </div>
                                </div>
                                <div class="container o_kanban_card_content">
                                    <div class="row">
                                        <div class="col-6 o_kanban_primary_left">
                                            <button class="btn btn-primary" name="open_livres"
                                                    type="object" style="background-color:%color">Livres
                                            </button>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        <!-- actions opening views on models -->
        <record model="ir.actions.act_window" id="etiquette_action_window">
            <field name="name">List des etiquettes</field>
            <field name="res_model">bibliotheque.etiquette</field>
            <field name="view_mode">kanban,tree,form</field>
        </record>

        <!-- Top menu item -->

        <menuitem name="Bibliothèque" id="bibliotheque.menu_root"/>

        <!-- menu categories -->

        <menuitem name="Etiquettes" id="etiquette_menu_cat" parent="bibliotheque.menu_root"
                  action="etiquette_action_window" sequence="2" />
    </data>
</odoo>