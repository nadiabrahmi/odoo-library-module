<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.module.category" id="module_category_school">
            <field name="name">Gestion de la bibliothèque</field>
            <field name="description">Category for School</field>
        </record>
        <record id="group_bibliotheque_enseignant" model="res.groups">
            <field name="name">Enseignant</field>
            <field name="category_id" ref="module_category_school"/>
        </record>
        <record id="group_bibliotheque_admin" model="res.groups">
            <field name="name">Administrateur</field>
            <field name="category_id" ref="module_category_school"/>
            <field name="implied_ids" eval="[(4, ref('group_bibliotheque_enseignant')),]"/>
        </record>
    </data>
</odoo>